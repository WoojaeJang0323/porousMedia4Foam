FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      C_Ba;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1.5;
    }
    inlet2
    {
        type            fixedValue;
        value           uniform 0;
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            zeroGradient;
    }
    topAndBottom
    {
        type            zeroGradient;
    }
    oldInternalFaces
    {
        type            zeroGradient;
    }
}


