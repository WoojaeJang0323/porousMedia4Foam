     \\/     M anipulation  |
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      C_Ba;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1.5;    // 1.5 mM Ba-rich
    }
    inlet2
    {
        type            fixedValue;
        value           uniform 0;      // no Ba from SO4-rich inlet
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            zeroGradient;
    }
    topAndBottom
    {
        type            zeroGradient;
    }
    ".*"
    {
        type            zeroGradient;
    }
}

// ************************************************************************* //
